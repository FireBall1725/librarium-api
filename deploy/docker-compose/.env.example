# Copy to .env (in this directory) and edit for a self-hosted deployment.
# The top-level .env.example is for running the Go server directly during
# development and is not used by this compose file.

# --- Required ---

# Long random string used to sign JWTs. Generate with:
#   openssl rand -base64 48
JWT_SECRET=

# Password for the bundled Postgres container. Any strong string.
POSTGRES_PASSWORD=

# --- Optional ---

# Port the web UI is exposed on (the API is only reachable through the web
# service's nginx proxy; it is not published externally).
WEB_PORT=3000

# Image tags to deploy. Pin to a specific release (e.g. 26.4.0) in production so
# upgrades are explicit. "latest" follows the newest published image.
API_TAG=latest
WEB_TAG=latest

# Override if you use a non-default database name/user.
POSTGRES_DB=librarium
POSTGRES_USER=librarium

# API log level: debug | info | warn | error
LOG_LEVEL=info

# --- Storage ---
#
# Covers always live on the `cover_data` Docker named volume — they're small
# and tightly coupled to the database, so backup them together.
#
# Media (ebooks + audiobooks) default to a Docker named volume too, but most
# self-hosters prefer to point them at an existing library share (NAS, NFS
# mount, etc.). To do that, uncomment and set MEDIA_PATH to an absolute host
# path. Docker will bind-mount it instead of using the internal volume.
#
# MEDIA_PATH=/mnt/library
